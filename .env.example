DATABASE_URL=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PrivateEmail SMTP settings for app-owned auth and lifecycle emails.
# Supabase Auth creates/verifies tokens, but BareUnity sends the email bodies
# through src/lib/email.ts.
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=jeroen@bareunity.com
SMTP_PASS=
EMAIL_FROM="BareUnity <jeroen@bareunity.com>"

EMAIL_LOGO_URL=

# Discord OAuth setup for Supabase Auth:
# 1. In the Discord Developer Portal, create/select an application and copy the OAuth2 Client ID/Secret.
# 2. Add the Supabase callback URL to Discord OAuth2 Redirects:
#    https://<your-supabase-project-ref>.supabase.co/auth/v1/callback
# 3. Enable Discord in Supabase Dashboard > Authentication > Providers using these credentials.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord bot role check for TeamNaturist invite registration.
# Create a Discord application bot, invite it to the TeamNaturist server with
# Server Members Intent enabled, and keep the token server-side only.
DISCORD_BOT_TOKEN=
DISCORD_TEAMNATURIST_GUILD_ID=1130957278472835234
DISCORD_TEAMNATURIST_ROLE_IDS=1131278113167388742,1131284261748625510,1130958613008089128,1171098977043755138
