# BareUnity local development environment
# Copy this file to .env.local and fill in real values.

# Supabase public client/auth config. These are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase admin/server fallback config. Keep this secret; never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Prisma/Postgres connections from Supabase project settings.
# Runtime should use the pooled connection; DIRECT_URL should use the direct database host.
DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres"

# Production admin allow-list. Comma-separate multiple owner/admin emails.
PLATFORM_ADMIN_EMAILS="admin@example.com"

# Rich Google stay/place details for admin imports.
# Enable Places API and Geocoding API on this key. Keep it server-only.
GOOGLE_MAPS_API_KEY="your-google-server-api-key"
# Optional alias if you prefer a narrower name; GOOGLE_MAPS_API_KEY is enough.
# GOOGLE_PLACES_API_KEY="your-google-server-api-key"

# Server-side Mapbox coordinate cross-check for admin imports/stay geocoding.
# Keep it server-only unless you separately add a browser map token.
MAPBOX_ACCESS_TOKEN="your-mapbox-server-token"

# Auth.js / GitHub auth, if using the GitHub provider.
AUTH_SECRET="generate-with-openssl-rand-base64-32"
GITHUB_ID="your-github-oauth-client-id"
GITHUB_SECRET="your-github-oauth-client-secret"

# Optional import enrichment/geocoding integrations already supported elsewhere.
# OLLAMA_API_BASE_URL="https://ollama.com/api"
# OLLAMA_API_KEY="your-ollama-api-key"
# OLLAMA_STAYS_MODEL="gpt-oss:120b"
# GEOAPIFY_API_KEY="your-geoapify-api-key"
